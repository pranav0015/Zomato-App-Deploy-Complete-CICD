pipeline{
    agent any
    
    parameters{
        string(name: 'Image_Tag', defaultValue: 'latest', description: 'Docker_Image_Tag')
        string(name: 'EKS_Cluster_Name', defaultValue: 'zomato-app-eks', description: 'Enter the EKS Cluster Name')
    }

    stages(){
        stage("Git Checkout"){
            steps{
                git branch: 'main', credentialsId: 'github-token', url: 'https://github.com/pranav0015/Zomato-App-Deploy-Complete-CICD.git'
            }
        }

        stage("Update Kubernetes Manifesh and Push to Github"){
            steps{
                sh """
                 # replace the docker image tag with the latest build number and updated the deployment file

                 sed -i "s|zomato-ecr-image:.*|zomato-ecr-image:${params.Image_Tag}|g" "./Kubernetes/deployment-service.yaml"

                 cat "./Kubernetes/deployment-service.yaml"

                 git add "./Kubernetes/deployment-service.yaml" 

                 git commit -m "Updated the image tag with the latest ${params.Image_Tag}" || echo "nothing to commit"
                 
                 """

                 withCredentials([gitUsernamePassword(credentialsId: 'github-token', gitToolName: 'Default')]) {
                        sh """
                            git push https://github.com/pranav0015/Zomato-App-Deploy-Complete-CICD.git
                        """
                     }
                }
            }
    }

    
    post {
    success {
        script {

            def body = """
            <html>
            <body>

            <div style="border: 4px solid green; padding: 15px; border-radius: 10px;">

            <h2>CD Pipeline Success - Build #${BUILD_NUMBER}</h2>

            <div style="background-color: green; padding: 10px; border-radius: 5px;">
                <h3 style="color: white;">
                    Deployment Status: SUCCESS
                </h3>
            </div>

            <br>

            <table border="1" cellpadding="8" cellspacing="0" width="100%">
                <tr>
                    <th align="left">Pipeline</th>
                    <td>${JOB_NAME}</td>
                </tr>

                <tr>
                    <th align="left">Build Number</th>
                    <td>${BUILD_NUMBER}</td>
                </tr>

                <tr>
                    <th align="left">Environment</th>
                    <td>Production</td>
                </tr>

                <tr>
                    <th align="left">EKS Cluster</th>
                    <td>${params.EKS_Cluster_Name}</td>
                </tr>

                <tr>
                    <th align="left">Build URL</th>
                    <td>
                        <a href="${env.BUILD_URL}">
                            Open Jenkins Build
                        </a>
                    </td>
                </tr>
            </table>

            <br>

            <h3>Deployment Summary</h3>

            <ul>
                <li>Application deployed successfully</li>
                <li>ArgoCD sync completed</li>
                <li>Kubernetes resources updated</li>
                <li>Monitoring stack verified</li>
            </ul>

            </div>

            </body>
            </html>
            """

            emailext(
                subject: "SUCCESS: CD Pipeline - Build #${BUILD_NUMBER}",
                body: body,
                to: 'waktepranav00@gmail.com',
                from: 'jenkins@example.com',
                replyTo: 'jenkins@example.com',
                mimeType: 'text/html'
            )
        }
    }

    failure {
        script {

            def body = """
            <html>
            <body>

            <div style="border: 4px solid red; padding: 15px; border-radius: 10px;">

            <h2>CD Pipeline Failed - Build #${BUILD_NUMBER}</h2>

            <div style="background-color: red; padding: 10px; border-radius: 5px;">
                <h3 style="color: white;">
                    Deployment Status: FAILED
                </h3>
            </div>

            <br>

            <table border="1" cellpadding="8" cellspacing="0" width="100%">
                <tr>
                    <th align="left">Pipeline</th>
                    <td>${JOB_NAME}</td>
                </tr>

                <tr>
                    <th align="left">Build Number</th>
                    <td>${BUILD_NUMBER}</td>
                </tr>

                <tr>
                    <th align="left">Environment</th>
                    <td>Production</td>
                </tr>

                <tr>
                    <th align="left">EKS Cluster</th>
                    <td>${params.EKS_Cluster_Name}</td>
                </tr>

                <tr>
                    <th align="left">Build URL</th>
                    <td>
                        <a href="${env.BUILD_URL}">
                            Open Jenkins Console Logs
                        </a>
                    </td>
                </tr>
            </table>

            <br>

            <h3>Possible Failure Reasons</h3>

            <ul>
                <li>Kubernetes deployment failure</li>
                <li>ArgoCD sync issue</li>
                <li>Helm installation error</li>
                <li>Cluster connectivity issue</li>
                <li>Container crash or image pull issue</li>
            </ul>

            <br>

            <p>
                Please check Jenkins console logs for detailed troubleshooting.
            </p>

            </div>

            </body>
            </html>
            """

            emailext(
                subject: "FAILED: CD Pipeline - Build #${BUILD_NUMBER}",
                body: "CD Pipeline failed.",
                to: 'waktepranav00@gmail.com',
                from: 'jenkins@example.com',
                replyTo: 'jenkins@example.com',
                mimeType: 'text/html'
            )
        }
    }
}
}